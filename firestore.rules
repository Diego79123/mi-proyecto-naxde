rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NAXDE DIGITAL HUB SECURITY RULES
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a Role-Based Access Control (RBAC) model combined with a visibility-based 
     * public access model. It prioritizes "Authorization Independence," meaning a document's visibility 
     * is determined by its own state (e.g., an 'isActive' flag) rather than complex hierarchical lookups.
     *
     * DATA STRUCTURE:
     * - Flat Top-Level Collections: All content (Services, Products, Blog Posts, etc.) are at the root.
     * - Role Collections: '/roles_admin' and '/roles_editor' store UIDs to grant elevated privileges.
     * - Lead Capture: '/leads' and '/card_requests' are write-only for the public and staff-only for management.
     *
     * KEY SECURITY DECISIONS:
     * - Public Read Access: Granted to most content collections only if the document's 'isActive' field is true.
     * - Staff Access: Users present in 'roles_admin' or 'roles_editor' have full management capabilities.
     * - Denormalization: Authorization relies on local 'isActive' flags and atomic 'exists()' role checks 
     *   to ensure performance and avoid deep nesting.
     * - Prototyping Mode: Schema validation is minimal, focusing only on critical fields like 'authorId' 
     *   or 'id' to maintain relational integrity while allowing rapid iteration.
     */

    // --- HELPER FUNCTIONS ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user has the 'admin' role. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** @description Checks if the user has the 'editor' role. */
    function isEditor() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_editor/$(request.auth.uid));
    }

    /** @description Checks if the user is either an admin or an editor. */
    function isStaff() {
      return isAdmin() || isEditor();
    }

    /** @description Checks if a document is marked as active for public consumption. */
    function isActive() {
      return resource.data.isActive == true;
    }

    /** @description Validates that the document exists for update or delete operations. */
    function existsForWrite() {
      return resource != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Global platform settings and brand configuration.
     * @path /site_settings/{settingsId}
     * @allow (get) Public access for site rendering.
     * @deny (create) Anonymous user trying to modify brand colors.
     * @principle Role-based write access with public read.
     */
    match /site_settings/{settingsId} {
      allow get, list: if true;
      allow create: if isStaff();
      allow update, delete: if isStaff() && existsForWrite();
    }

    /**
     * @description Publicly visible content collections (Services, Products, Projects, etc.).
     * @path /{contentCollection}/{docId}
     * @allow (list) Public user viewing active services.
     * @deny (get) Public user viewing a 'draft' blog post (isActive: false).
     * @principle Visibility-based read access (isActive) and staff-only writes.
     */
    match /services/{docId} {
      allow get, list: if isActive() || isStaff();
      allow create: if isStaff();
      allow update, delete: if isStaff() && existsForWrite();
    }

    match /products/{docId} {
      allow get, list: if isActive() || isStaff();
      allow create: if isStaff();
      allow update, delete: if isStaff() && existsForWrite();
    }

    match /projects/{docId} {
      allow get, list: if isActive() || isStaff();
      allow create: if isStaff();
      allow update, delete: if isStaff() && existsForWrite();
    }

    match /testimonials/{docId} {
      allow get, list: if isActive() || isStaff();
      allow create: if isStaff();
      allow update, delete: if isStaff() && existsForWrite();
    }

    match /faqs/{docId} {
      allow get, list: if isActive() || isStaff();
      allow create: if isStaff();
      allow update, delete: if isStaff() && existsForWrite();
    }

    match /plans/{docId} {
      allow get, list: if isActive() || isStaff();
      allow create: if isStaff();
      allow update, delete: if isStaff() && existsForWrite();
    }

    match /team_members/{docId} {
      allow get, list: if isActive() || isStaff();
      allow create: if isStaff();
      allow update, delete: if isStaff() && existsForWrite();
    }

    match /card_products/{docId} {
      allow get, list: if isActive() || isStaff();
      allow create: if isStaff();
      allow update, delete: if isStaff() && existsForWrite();
    }

    /**
     * @description Blog posts with relational integrity check for authors.
     * @path /blog_posts/{blogPostId}
     * @allow (create) An editor creating a post with their own authorId.
     * @deny (update) Changing the authorId of an existing post.
     * @principle Immutability of relational fields during updates.
     */
    match /blog_posts/{blogPostId} {
      allow get, list: if isActive() || isStaff();
      allow create: if isStaff() && request.resource.data.authorId != null;
      allow update: if isStaff() && existsForWrite() && 
                    request.resource.data.authorId == resource.data.authorId;
      allow delete: if isStaff() && existsForWrite();
    }

    /**
     * @description Lead capture for general inquiries and NFC card requests.
     * @path /leads/{leadId} or /card_requests/{cardRequestId}
     * @allow (create) Anonymous website visitor submitting a contact form.
     * @deny (list) Anonymous user trying to browse potential client data.
     * @principle Public "Write-Only" for ingestion, Staff "Read/Write" for management.
     */
    match /leads/{leadId} {
      allow create: if true;
      allow get, list: if isStaff();
      allow update, delete: if isStaff() && existsForWrite();
    }

    match /card_requests/{cardRequestId} {
      allow create: if true;
      allow get, list: if isStaff();
      allow update, delete: if isStaff() && existsForWrite();
    }

    /**
     * @description Admin role management.
     * @path /roles_admin/{userId}
     * @allow (get) Signed-in user checking if they are an admin.
     * @deny (create) Editor trying to promote themselves to admin.
     * @principle Root-level administrative privilege control.
     */
    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Editor role management.
     * @path /roles_editor/{userId}
     * @allow (get) Signed-in user checking if they are an editor.
     * @deny (update) Editor trying to modify another editor's status.
     * @principle Admin-only management of editor privileges.
     */
    match /roles_editor/{userId} {
      allow get: if isSignedIn();
      allow list: if isStaff();
      allow create, update, delete: if isAdmin();
    }
  }
}